<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>InfoCaption Dashboard</display-name>

    <!-- Startup Listener — loads secrets before servlets initialize -->
    <listener>
        <listener-class>com.infocaption.dashboard.util.AppStartupListener</listener-class>
    </listener>

    <!-- Character Encoding Filter -->
    <filter>
        <filter-name>EncodingFilter</filter-name>
        <filter-class>com.infocaption.dashboard.filter.EncodingFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>EncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- Auth Filter -->
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>com.infocaption.dashboard.filter.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/dashboard.jsp</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/modules/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/api/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/module/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/create-module.jsp</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/manage-modules.jsp</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/group/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/manage-groups.jsp</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/admin.jsp</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/manage-users</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/manage-users.jsp</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/settings.jsp</url-pattern>
    </filter-mapping>

    <!-- CSRF Filter -->
    <filter>
        <filter-name>CsrfFilter</filter-name>
        <filter-class>com.infocaption.dashboard.filter.CsrfFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>CsrfFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- Security Headers Filter -->
    <filter>
        <filter-name>SecurityHeaderFilter</filter-name>
        <filter-class>com.infocaption.dashboard.filter.SecurityHeaderFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>SecurityHeaderFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- Body Size Limit Filter (1 MB max for non-multipart requests) -->
    <filter>
        <filter-name>BodySizeLimitFilter</filter-name>
        <filter-class>com.infocaption.dashboard.filter.BodySizeLimitFilter</filter-class>
        <init-param>
            <param-name>maxBytes</param-name>
            <param-value>1048576</param-value>
        </init-param>
    </filter>
    <filter-mapping>
        <filter-name>BodySizeLimitFilter</filter-name>
        <url-pattern>/api/*</url-pattern>
    </filter-mapping>

    <!-- Rate Limit Filter for login/register (10 POST requests per 60 seconds per IP) -->
    <filter>
        <filter-name>RateLimitFilter</filter-name>
        <filter-class>com.infocaption.dashboard.filter.RateLimitFilter</filter-class>
        <init-param>
            <param-name>maxRequests</param-name>
            <param-value>10</param-value>
        </init-param>
        <init-param>
            <param-name>windowSeconds</param-name>
            <param-value>60</param-value>
        </init-param>
    </filter>
    <filter-mapping>
        <filter-name>RateLimitFilter</filter-name>
        <url-pattern>/login</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>RateLimitFilter</filter-name>
        <url-pattern>/register</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>RateLimitFilter</filter-name>
        <url-pattern>/api/cloudguard/*</url-pattern>
    </filter-mapping>

    <!-- Content-Type Validation Filter -->
    <filter>
        <filter-name>ContentTypeValidationFilter</filter-name>
        <filter-class>com.infocaption.dashboard.filter.ContentTypeValidationFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>ContentTypeValidationFilter</filter-name>
        <url-pattern>/api/*</url-pattern>
    </filter-mapping>

    <!-- Servlets -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.infocaption.dashboard.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.infocaption.dashboard.servlet.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.infocaption.dashboard.servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <!-- Module API Servlet -->
    <servlet>
        <servlet-name>ModuleApiServlet</servlet-name>
        <servlet-class>com.infocaption.dashboard.servlet.ModuleApiServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ModuleApiServlet</servlet-name>
        <url-pattern>/api/modules</url-pattern>
    </servlet-mapping>

    <!-- Module Create Servlet -->
    <servlet>
        <servlet-name>ModuleCreateServlet</servlet-name>
        <servlet-class>com.infocaption.dashboard.servlet.ModuleCreateServlet</servlet-class>
        <multipart-config>
            <max-file-size>52428800</max-file-size>
            <max-request-size>52428800</max-request-size>
            <file-size-threshold>1048576</file-size-threshold>
        </multipart-config>
    </servlet>
    <servlet-mapping>
        <servlet-name>ModuleCreateServlet</servlet-name>
        <url-pattern>/module/create</url-pattern>
    </servlet-mapping>

    <!-- Module Manage Servlet -->
    <servlet>
        <servlet-name>ModuleManageServlet</servlet-name>
        <servlet-class>com.infocaption.dashboard.servlet.ModuleManageServlet</servlet-class>
        <multipart-config>
            <max-file-size>52428800</max-file-size>
            <max-request-size>52428800</max-request-size>
            <file-size-threshold>1048576</file-size-threshold>
        </multipart-config>
    </servlet>
    <servlet-mapping>
        <servlet-name>ModuleManageServlet</servlet-name>
        <url-pattern>/module/manage</url-pattern>
    </servlet-mapping>

    <!-- Module File API Servlet (Admin) -->
    <servlet>
        <servlet-name>ModuleFileApiServlet</servlet-name>
        <servlet-class>com.infocaption.dashboard.servlet.ModuleFileApiServlet</servlet-class>
        <multipart-config>
            <max-file-size>10485760</max-file-size>
            <max-request-size>10485760</max-request-size>
            <file-size-threshold>1048576</file-size-threshold>
        </multipart-config>
    </servlet>
    <servlet-mapping>
        <servlet-name>ModuleFileApiServlet</servlet-name>
        <url-pattern>/api/admin/modules/*</url-pattern>
    </servlet-mapping>

    <!-- Module Spec Servlet -->
    <servlet>
        <servlet-name>ModuleSpecServlet</servlet-name>
        <servlet-class>com.infocaption.dashboard.servlet.ModuleSpecServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ModuleSpecServlet</servlet-name>
        <url-pattern>/api/module/spec</url-pattern>
    </servlet-mapping>

    <!-- Customer Stats API Servlet -->
    <servlet>
        <servlet-name>CustomerStatsApiServlet</servlet-name>
        <servlet-class>com.infocaption.dashboard.servlet.CustomerStatsApiServlet</servlet-class>
        <load-on-startup>1</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>CustomerStatsApiServlet</servlet-name>
        <url-pattern>/api/customer-stats</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>CustomerStatsApiServlet</servlet-name>
        <url-pattern>/api/customer-stats/*</url-pattern>
    </servlet-mapping>

    <!-- Email API Servlet -->
    <servlet>
        <servlet-name>EmailApiServlet</servlet-name>
        <servlet-class>com.infocaption.dashboard.servlet.EmailApiServlet</servlet-class>
        <load-on-startup>2</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>EmailApiServlet</servlet-name>
        <url-pattern>/api/email/*</url-pattern>
    </servlet-mapping>

    <!-- Contact List API Servlet (Listor/Lists feature in Utskick module) -->
    <servlet>
        <servlet-name>ContactListServlet</servlet-name>
        <servlet-class>com.infocaption.dashboard.servlet.ContactListServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ContactListServlet</servlet-name>
        <url-pattern>/api/contacts/*</url-pattern>
    </servlet-mapping>

    <!-- Server List API Servlet -->
    <servlet>
        <servlet-name>ServerListApiServlet</servlet-name>
        <servlet-class>com.infocaption.dashboard.servlet.ServerListApiServlet</servlet-class>
        <load-on-startup>3</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>ServerListApiServlet</servlet-name>
        <url-pattern>/api/servers</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ServerListApiServlet</servlet-name>
        <url-pattern>/api/servers/*</url-pattern>
    </servlet-mapping>

    <!-- Group API Servlet -->
    <servlet>
        <servlet-name>GroupApiServlet</servlet-name>
        <servlet-class>com.infocaption.dashboard.servlet.GroupApiServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>GroupApiServlet</servlet-name>
        <url-pattern>/api/groups</url-pattern>
    </servlet-mapping>

    <!-- Group Manage Servlet -->
    <servlet>
        <servlet-name>GroupManageServlet</servlet-name>
        <servlet-class>com.infocaption.dashboard.servlet.GroupManageServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>GroupManageServlet</servlet-name>
        <url-pattern>/group/manage</url-pattern>
    </servlet-mapping>

    <!-- User Manage Servlet -->
    <servlet>
        <servlet-name>UserManageServlet</servlet-name>
        <servlet-class>com.infocaption.dashboard.servlet.UserManageServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UserManageServlet</servlet-name>
        <url-pattern>/manage-users</url-pattern>
    </servlet-mapping>

    <!-- Admin API Servlet -->
    <servlet>
        <servlet-name>AdminApiServlet</servlet-name>
        <servlet-class>com.infocaption.dashboard.servlet.AdminApiServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminApiServlet</servlet-name>
        <url-pattern>/api/admin/*</url-pattern>
    </servlet-mapping>

    <!-- Sync Config API Servlet -->
    <servlet>
        <servlet-name>SyncConfigServlet</servlet-name>
        <servlet-class>com.infocaption.dashboard.servlet.SyncConfigServlet</servlet-class>
        <load-on-startup>4</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>SyncConfigServlet</servlet-name>
        <url-pattern>/api/sync/*</url-pattern>
    </servlet-mapping>

    <!-- Sync Scheduler Servlet (background jobs) -->
    <servlet>
        <servlet-name>SyncSchedulerServlet</servlet-name>
        <servlet-class>com.infocaption.dashboard.servlet.SyncSchedulerServlet</servlet-class>
        <load-on-startup>5</load-on-startup>
    </servlet>

    <!-- Certificate API Servlet -->
    <servlet>
        <servlet-name>CertificateApiServlet</servlet-name>
        <servlet-class>com.infocaption.dashboard.servlet.CertificateApiServlet</servlet-class>
        <load-on-startup>6</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>CertificateApiServlet</servlet-name>
        <url-pattern>/api/certificates</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>CertificateApiServlet</servlet-name>
        <url-pattern>/api/certificates/*</url-pattern>
    </servlet-mapping>

    <!-- Widget API Servlet -->
    <servlet>
        <servlet-name>WidgetApiServlet</servlet-name>
        <servlet-class>com.infocaption.dashboard.servlet.WidgetApiServlet</servlet-class>
        <load-on-startup>7</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>WidgetApiServlet</servlet-name>
        <url-pattern>/api/widgets</url-pattern>
    </servlet-mapping>

    <!-- User Preferences API Servlet -->
    <servlet>
        <servlet-name>UserPreferencesApiServlet</servlet-name>
        <servlet-class>com.infocaption.dashboard.servlet.UserPreferencesApiServlet</servlet-class>
        <load-on-startup>8</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>UserPreferencesApiServlet</servlet-name>
        <url-pattern>/api/preferences</url-pattern>
    </servlet-mapping>

    <!-- User Settings API Servlet -->
    <servlet>
        <servlet-name>UserSettingsServlet</servlet-name>
        <servlet-class>com.infocaption.dashboard.servlet.UserSettingsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UserSettingsServlet</servlet-name>
        <url-pattern>/api/user/settings</url-pattern>
    </servlet-mapping>

    <!-- Avatar Upload Servlet -->
    <servlet>
        <servlet-name>AvatarUploadServlet</servlet-name>
        <servlet-class>com.infocaption.dashboard.servlet.AvatarUploadServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AvatarUploadServlet</servlet-name>
        <url-pattern>/api/user/avatar</url-pattern>
    </servlet-mapping>

    <!-- Jira API Servlet -->
    <servlet>
        <servlet-name>JiraApiServlet</servlet-name>
        <servlet-class>com.infocaption.dashboard.servlet.JiraApiServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>JiraApiServlet</servlet-name>
        <url-pattern>/api/jira/*</url-pattern>
    </servlet-mapping>

    <!-- Guide Planner API Servlet -->
    <servlet>
        <servlet-name>GuidePlannerApiServlet</servlet-name>
        <servlet-class>com.infocaption.dashboard.servlet.GuidePlannerApiServlet</servlet-class>
        <load-on-startup>9</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>GuidePlannerApiServlet</servlet-name>
        <url-pattern>/api/guide-planner/*</url-pattern>
    </servlet-mapping>

    <!-- API Token Servlet (personal token management) -->
    <servlet>
        <servlet-name>ApiTokenServlet</servlet-name>
        <servlet-class>com.infocaption.dashboard.servlet.ApiTokenServlet</servlet-class>
        <load-on-startup>11</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>ApiTokenServlet</servlet-name>
        <url-pattern>/api/tokens</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ApiTokenServlet</servlet-name>
        <url-pattern>/api/tokens/*</url-pattern>
    </servlet-mapping>

    <!-- Drift Monitor API Servlet -->
    <servlet>
        <servlet-name>DriftMonitorApiServlet</servlet-name>
        <servlet-class>com.infocaption.dashboard.servlet.DriftMonitorApiServlet</servlet-class>
        <load-on-startup>10</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>DriftMonitorApiServlet</servlet-name>
        <url-pattern>/api/drift/*</url-pattern>
    </servlet-mapping>

    <!-- CloudGuard Incident Reporting API Servlet -->
    <servlet>
        <servlet-name>CloudGuardApiServlet</servlet-name>
        <servlet-class>com.infocaption.dashboard.servlet.CloudGuardApiServlet</servlet-class>
        <load-on-startup>12</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>CloudGuardApiServlet</servlet-name>
        <url-pattern>/api/cloudguard/*</url-pattern>
    </servlet-mapping>

    <!-- Incident Reports API Servlet -->
    <servlet>
        <servlet-name>IncidentApiServlet</servlet-name>
        <servlet-class>com.infocaption.dashboard.servlet.IncidentApiServlet</servlet-class>
        <load-on-startup>13</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>IncidentApiServlet</servlet-name>
        <url-pattern>/api/incidents/*</url-pattern>
    </servlet-mapping>

    <!-- Backup Status API Servlet -->
    <servlet>
        <servlet-name>BackupStatusApiServlet</servlet-name>
        <servlet-class>com.infocaption.dashboard.servlet.BackupStatusApiServlet</servlet-class>
        <load-on-startup>14</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>BackupStatusApiServlet</servlet-name>
        <url-pattern>/api/backups</url-pattern>
    </servlet-mapping>

    <!-- Version API Servlet -->
    <servlet>
        <servlet-name>VersionServlet</servlet-name>
        <servlet-class>com.infocaption.dashboard.servlet.VersionServlet</servlet-class>
        <load-on-startup>15</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>VersionServlet</servlet-name>
        <url-pattern>/api/version</url-pattern>
    </servlet-mapping>

    <!-- Notification API Servlet (push subscriptions) -->
    <servlet>
        <servlet-name>NotificationServlet</servlet-name>
        <servlet-class>com.infocaption.dashboard.servlet.NotificationServlet</servlet-class>
        <load-on-startup>17</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>NotificationServlet</servlet-name>
        <url-pattern>/api/notifications/*</url-pattern>
    </servlet-mapping>

    <!-- Knowledge Base Admin Servlet (document & collection CRUD) -->
    <servlet>
        <servlet-name>KbAdminServlet</servlet-name>
        <servlet-class>com.infocaption.dashboard.servlet.KbAdminServlet</servlet-class>
        <load-on-startup>19</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>KbAdminServlet</servlet-name>
        <url-pattern>/api/admin/kb/*</url-pattern>
    </servlet-mapping>

    <!-- MCP Gateway Servlet (JSON-RPC 2.0 endpoint) -->
    <servlet>
        <servlet-name>McpGatewayServlet</servlet-name>
        <servlet-class>com.infocaption.dashboard.servlet.McpGatewayServlet</servlet-class>
        <load-on-startup>16</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>McpGatewayServlet</servlet-name>
        <url-pattern>/api/mcp</url-pattern>
    </servlet-mapping>

    <!-- MCP Admin Servlet (server config CRUD) -->
    <servlet>
        <servlet-name>McpAdminServlet</servlet-name>
        <servlet-class>com.infocaption.dashboard.servlet.McpAdminServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>McpAdminServlet</servlet-name>
        <url-pattern>/api/mcp/admin/*</url-pattern>
    </servlet-mapping>

    <!-- Tomcat Instance API Servlet (local Tomcat install management) -->
    <servlet>
        <servlet-name>TomcatInstanceApiServlet</servlet-name>
        <servlet-class>com.infocaption.dashboard.servlet.TomcatInstanceApiServlet</servlet-class>
        <load-on-startup>20</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>TomcatInstanceApiServlet</servlet-name>
        <url-pattern>/api/tomcat-instances</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>TomcatInstanceApiServlet</servlet-name>
        <url-pattern>/api/tomcat-instances/*</url-pattern>
    </servlet-mapping>

    <!-- Background Health Check Scheduler -->
    <servlet>
        <servlet-name>HealthCheckScheduler</servlet-name>
        <servlet-class>com.infocaption.dashboard.servlet.HealthCheckScheduler</servlet-class>
        <load-on-startup>18</load-on-startup>
    </servlet>

    <!-- SAML SSO Servlets -->
    <servlet>
        <servlet-name>SamlLoginServlet</servlet-name>
        <servlet-class>com.infocaption.dashboard.servlet.SamlLoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SamlLoginServlet</servlet-name>
        <url-pattern>/saml/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SamlAcsServlet</servlet-name>
        <servlet-class>com.infocaption.dashboard.servlet.SamlAcsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SamlAcsServlet</servlet-name>
        <url-pattern>/saml/acs</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SamlMetadataServlet</servlet-name>
        <servlet-class>com.infocaption.dashboard.servlet.SamlMetadataServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SamlMetadataServlet</servlet-name>
        <url-pattern>/saml/metadata</url-pattern>
    </servlet-mapping>

    <!-- Session timeout: 30 minutes -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- Force HTTPS on all requests.
         ONLY enable this if Tomcat handles SSL directly (port 8443 with keystore).
         When running behind a reverse proxy (Apache/Nginx) that handles SSL,
         leave this DISABLED — otherwise Tomcat will redirect to :8443. -->
    
    <security-constraint>
        <web-resource-collection>
            <web-resource-name>All</web-resource-name>
            <url-pattern>/*</url-pattern>
        </web-resource-collection>
        <user-data-constraint>
            <transport-guarantee>CONFIDENTIAL</transport-guarantee>
        </user-data-constraint>
    </security-constraint>
    

    <!-- Custom Error Pages -->
    <error-page>
        <error-code>400</error-code>
        <location>/error.jsp</location>
    </error-page>
    <error-page>
        <error-code>401</error-code>
        <location>/error.jsp</location>
    </error-page>
    <error-page>
        <error-code>403</error-code>
        <location>/error.jsp</location>
    </error-page>
    <error-page>
        <error-code>404</error-code>
        <location>/error.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/error.jsp</location>
    </error-page>
    <error-page>
        <exception-type>java.lang.Throwable</exception-type>
        <location>/error.jsp</location>
    </error-page>

    <!-- Welcome file -->
    <welcome-file-list>
        <welcome-file>login</welcome-file>
    </welcome-file-list>
</web-app>
